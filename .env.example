# Copy this file to .env and fill in your own key. Never share this file or paste
# your key into a chat with anyone, including an AI assistant. On Render, these
# are set in the dashboard under your service's "Environment" tab instead of a
# real .env file — the values below are just for local testing.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides:
# PORT=3000
# CLAUDE_MODEL=claude-sonnet-5
# INSIGHTS_MODEL=claude-haiku-4-5-20251001

# Email notifications (optional). If these are left blank, chat transcripts and
# follow-up requests simply aren't emailed anywhere — the site still works fine.
# Sent via Resend's HTTPS API (RESEND_API_KEY doubles as SMTP_PASS for
# backward compatibility with earlier setup steps).
OWNER_EMAIL=you@yourcompany.com
RESEND_API_KEY=re_your_resend_api_key_here
SMTP_FROM=director@litigationfinanceinstitute.com

# Optional: Google Sheets webhook (Apps Script Web App URL) that receives a
# structured, anonymized tag for every AI Concierge conversation — audience
# type, matter category, claim size range, jurisdiction, key topics. If left
# blank, this data is still captured locally to data/insights.jsonl and viewable
# at /api/insights-summary; the webhook just also mirrors it into a live,
# human-readable Google Sheet. See RUNNING_LOCALLY.md for setup.
# INSIGHTS_WEBHOOK_URL=https://script.google.com/macros/s/your-deployment-id/exec
